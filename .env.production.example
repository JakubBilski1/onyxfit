# ──────────────────────────────────────────────────────────────────────────
# Production env vars to set in Vercel Project Settings → Environment Variables
# (or via `npx vercel env add <NAME>` after `vercel link`).
# ──────────────────────────────────────────────────────────────────────────

# Supabase — same project as local
NEXT_PUBLIC_SUPABASE_URL=https://rzpbjtjpinxufygpwhuo.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<paste your anon key>
SUPABASE_SERVICE_ROLE_KEY=<paste your service role key>

# App URL — replace with your Vercel domain (or custom domain) after first deploy
NEXT_PUBLIC_APP_URL=https://onyxcoach.vercel.app

# Mailer
MAIL_DRIVER=gmail
MAIL_FROM=Onyx Coach <orvana.group@gmail.com>
MAIL_REPLY_TO=orvana.group@gmail.com
MAIL_SUPPORT_ADDRESS=orvana.group@gmail.com
# Comment out for real production — only for testing
MAIL_TEST_OVERRIDE_TO=orvana.group@gmail.com
GMAIL_USER=orvana.group@gmail.com
GMAIL_APP_PASSWORD=<paste 16-char app password>
